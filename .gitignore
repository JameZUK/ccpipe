state/
credentials
session_secret
*.credentials
*.session_secret

# Editor + OS detritus
.DS_Store
Thumbs.db
*.swp
*.swo

# Logs
*.log

# Ad-hoc screenshots & scratch files
Screenshot*
scratch/
tmp/

# Claude Code workspace state (not part of ccpipe itself)
.claude/

# vite/tsc incremental build cache (don't ship)
tsconfig.tsbuildinfo
