# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
*.egg-info/

# Node
node_modules/
dist/
.cache/

# Env / secrets — never commit these
.env
.env.local
*.local

# State / credentials produced by ccpipe at runtime
state/
credentials
session_secret
*.credentials
*.session_secret

# Editor + OS detritus
.DS_Store
Thumbs.db
*.swp
*.swo

# Logs
*.log

# Ad-hoc screenshots & scratch files
Screenshot*
scratch/
tmp/
temp/

# External pentest / audit deliverables. Anchored to root so they
# don't accidentally hide e.g. docs/report.md.
/report.md
/report-*.md

# Claude Code workspace state (not part of ccpipe itself)
.claude/

# Local agent-skills installs (per-machine tooling, not part of the project)
.agents/
skills-lock.json

# vite/tsc incremental build cache (don't ship)
tsconfig.tsbuildinfo
